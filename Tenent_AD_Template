								{
									"type": "EXEC",
									"name": "Prepare_Config_Scripts",
									"description": "",
									"attrs": {
										"type": "",
										"script": "# ====================================================================\n# 1. Calm Macros isoliert in PowerShell-Variablen laden (Best Practice)\n# ====================================================================\n$DomainName = \"@@{domain_name}@@\"\n$DomainTld  = \"@@{domain_tld}@@\"\n$CompName   = \"@@{computer_name}@@\"\n$AdminUser  = \"@@{local_admin.username}@@\"\n$AdminPass  = \"@@{local_admin.secret}@@\"\n\n# PowerShell übernimmt das Zusammenbauen (Concatenation)\n$FullDomain = \"$DomainName.$DomainTld\"\n$LogonUser  = \"$DomainName\\$AdminUser\"\n$Fqdn       = \"$CompName.$DomainName.$DomainTld\".ToLower()\n\n# ====================================================================\n# 2. Ordner anlegen\n# ====================================================================\n$scriptPath = \"C:\\Config_Scripts\"\nif (!(Test-Path $scriptPath)) {\n    New-Item -ItemType Directory -Path $scriptPath -Force\n}\n\n# ====================================================================\n# 3. WindowsDC_01.ps1 erstellen\n# ====================================================================\n$Script01 = @\"\nSet-AutoLogon -DefaultUsername \"$LogonUser\" -DefaultPassword \"$AdminPass\"\nSet-Location -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\RunOnce'\nSet-ItemProperty -Path . -Name deployAD -Value 'C:\\WINDOWS\\system32\\WindowsPowerShell\\v1.0\\powershell.exe \"C:\\Config_Scripts\\WindowsDC_02.ps1\"'\nRename-Computer -NewName \"$CompName\"\nRestart-Computer\n\"@\n$Script01 | Out-File -FilePath \"C:\\Config_Scripts\\WindowsDC_01.ps1\" -Encoding UTF8\n\n# ====================================================================\n# 4. WindowsDC_02.ps1 erstellen\n# ====================================================================\n# Wichtig: Variablen, die in der Zieldatei Variablen bleiben sollen (wie $securepw),\n# bekommen einen Backtick (`). Unsere Werte wie $FullDomain werden direkt als Text eingefügt.\n$Script02 = @\"\n`$plainpw = \"$AdminPass\"\n`$securepw = ConvertTo-SecureString -AsPlainText `$plainpw -Force\n\nInstall-WindowsFeature AD-Domain-Services -IncludeAllSubFeature -IncludeManagementTools\nImport-Module ADDSDeployment\n\nInstall-ADDSForest -DomainName \"$FullDomain\" -DomainNetbiosName \"$DomainName\" -SafeModeAdministratorPassword `$securepw -CreateDnsDelegation:`$false -DomainMode \"Win2012R2\" -ForestMode \"Win2012R2\" -InstallDns:`$true -Force:`$true -NoRebootOnCompletion -DatabasePath \"C:\\Windows\\NTDS\" -LogPath \"C:\\Windows\\NTDS\" -SysvolPath \"C:\\Windows\\SYSVOL\"\n\nSet-AutoLogon -DefaultUsername \"$LogonUser\" -DefaultPassword \"$AdminPass\"\nSet-Location -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\RunOnce'\nSet-ItemProperty -Path . -Name addDomainUsers -Value 'C:\\WINDOWS\\system32\\WindowsPowerShell\\v1.0\\powershell.exe \"C:\\Config_Scripts\\WindowsDC_03.ps1\"'\nRestart-Computer\n\"@\n$Script02 | Out-File -FilePath \"C:\\Config_Scripts\\WindowsDC_02.ps1\" -Encoding UTF8\n\n# ====================================================================\n# 5. WindowsDC_03.ps1 erstellen (Auszug)\n# ====================================================================\n$Script03 = @\"\n`$password = \"$AdminPass\" | ConvertTo-SecureString -asPlainText -Force\n`$username = \"$LogonUser\" \n`$credential = New-Object System.Management.Automation.PSCredential(`$username,`$password)\n\nImport-module activedirectory\n`$Groups = Import-csv C:\\Config_Scripts\\WindowsDC_add-groups.csv\n\n`$OU = \"CN=Users, DC=$DomainName, DC=$DomainTld\"\n\nForEach(`$UserGroup in `$Groups) {\n    `$Group = `$UserGroup.group\n    New-ADGroup -Name `$Group -GroupScope Global -Credential `$credential\n    `$Users = Import-csv \"C:\\Config_Scripts\\WindowsDC_add-users_`$Group.csv\"\n    ForEach(`$User in `$Users) {\n        `$FullName = `$User.FirstName\n        `$SAM = `$User.FirstName.tolower()\n        `$dnsroot = '@' + (Get-ADDomain).dnsroot\n        `$UPN = `$SAM + \"`$dnsroot\"\n        New-ADUser -Name `$FullName -AccountPassword (ConvertTo-SecureString `$User.password -AsPlainText -force) -GivenName `$User.FirstName -Path `$OU -SamAccountName `$SAM -Surname `$User.LastName -UserPrincipalName `$UPN -Enabled `$TRUE -Credential `$credential\n        Add-ADGroupMember -Identity `$Group -Members `$SAM -Credential `$credential\n    }\n}\n\n# (Reverse DNS Code hier, falls benötigt)\n\nSet-AutoLogon -DefaultUsername \"$LogonUser\" -DefaultPassword \"$AdminPass\"\nSet-Location -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\RunOnce'\nSet-ItemProperty -Path . -Name \"finishDeployment\" -Value 'C:\\WINDOWS\\system32\\WindowsPowerShell\\v1.0\\powershell.exe \"C:\\Config_Scripts\\WindowsDC_04.ps1\"'\nRestart-Computer\n\"@\n$Script03 | Out-File -FilePath \"C:\\Config_Scripts\\WindowsDC_03.ps1\" -Encoding UTF8\n\n# ====================================================================\n# 6. WindowsDC_04.ps1 erstellen (Readiness Probe / Cleanup)\n# ====================================================================\n$Script04 = @\"\n`$rootCertStore = \"cert:\\LocalMachine\\Root\"\n`$tempCertFilePath = \"C:\\tempCert.cer\"\n\n`$interface = Get-NetAdapter | Where-Object { `$_.Name -like \"*Ethernet*\" } | Select-Object -First 1\n`$adServerIP = (Get-NetIPAddress -InterfaceAlias `$interface.Name -AddressFamily IPv4).IPAddress\n`$adServerFQDN = \"$Fqdn\"\n\n`$certificateParams = @{\n    DnsName = `$adServerIP, `$adServerFQDN\n    CertStoreLocation = \"cert:\\LocalMachine\\My\"\n    KeyUsage = \"KeyEncipherment\", \"DigitalSignature\"\n    KeyLength = 2048\n    KeyAlgorithm = \"RSA\"\n    HashAlgorithm = \"SHA256\"\n    NotAfter = (Get-Date).AddYears(1)\n    Provider = \"Microsoft Enhanced RSA and AES Cryptographic Provider\"\n    FriendlyName = \"LDAPS Certificate\"\n    TextExtension = @(\"2.5.29.37={text}1.3.6.1.5.5.7.3.1\")\n}\n\n`$cert = New-SelfSignedCertificate @certificateParams\nExport-Certificate -Cert `$cert -FilePath `$tempCertFilePath\nImport-Certificate -FilePath `$tempCertFilePath -CertStoreLocation `$rootCertStore\n\nRestart-Service -Name NTDS -Force\nw32tm /config /manualpeerlist:216.239.35.0,0x8 /syncfromflags:manual /reliable:yes /update\nSet-NetFirewallProfile -Profile Domain,Public,Private -Enabled False\n\n# AutoLogon Cleanup\n`$regPath = \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Winlogon\"\nSet-ItemProperty -Path `$regPath -Name \"AutoAdminLogon\" -Value \"0\"\nRemove-ItemProperty -Path `$regPath -Name \"DefaultUserName\" -ErrorAction SilentlyContinue\nRemove-ItemProperty -Path `$regPath -Name \"DefaultPassword\" -ErrorAction SilentlyContinue\nSet-Location -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\RunOnce'\nRemove-ItemProperty -Path . -Name \"finishDeployment\" -ErrorAction SilentlyContinue\n\n# HTTP Listener Start\nif (-not [System.Net.HttpListener]::IsSupported) { exit 1 }\n`$port = \"8000\"\n`$listener = New-Object System.Net.HttpListener\n`$url = -join (\"http://\", `$adServerIP, \":\", `$port, \"/\")\n`$listener.Prefixes.Add(`$url)\n\ntry { `$listener.Start() } catch { exit 1 }\n\nwhile (`$listener.IsListening) {\n    `$context = `$listener.GetContext()\n    `$response = `$context.Response\n    `$response.ContentType = \"text/plain\"\n    `$content = [System.Text.Encoding]::UTF8.GetBytes(\"AD Is Running\")\n    `$response.OutputStream.Write(`$content,0,`$content.Length)\n    `$response.Close()\n}\n`$listener.Stop()\n\"@\n$Script04 | Out-File -FilePath \"C:\\Config_Scripts\\WindowsDC_04.ps1\" -Encoding UTF8",
