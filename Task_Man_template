									{
										"type": "EXEC",
										"name": "Configure_WebServer",
										"description": "",
										"attrs": {
											"type": "",
											"script": "#!/bin/bash\nset -ex\n\n# Verzeichnis anlegen\nsudo mkdir -p /var/www/laravel\n\n# Nginx Konfiguration schreiben\necho \"server {\n listen 80 default_server;\n listen [::]:80 default_server ipv6only=on;\n root /var/www/laravel/public/;\n index index.php index.html index.htm;\n location / {\n  try_files \\$uri \\$uri/ /index.php?\\$query_string;\n }\n # pass the PHP scripts to FastCGI server listening on /var/run/php5-fpm.sock\n location ~ \\.php$ {\n  try_files \\$uri /index.php =404;\n  fastcgi_split_path_info ^(.+\\.php)(/.+)\\$;\n  fastcgi_pass 127.0.0.1:9000;\n  fastcgi_index index.php;\n  fastcgi_param SCRIPT_FILENAME \\$document_root\\$fastcgi_script_name;\n  include fastcgi_params;\n }\n}\" | sudo tee /etc/nginx/conf.d/laravel.conf\n\nsudo sed -i 's/80 default_server/80/g' /etc/nginx/nginx.conf\n\n# PHP cgi.fix_pathinfo setzen\nif grep -q \"cgi.fix_pathinfo\" /etc/php.ini ; then\n sudo sed -i 's/cgi.fix_pathinfo=1/cgi.fix_pathinfo=0/' /etc/php.ini\nelse\n sudo sed -i 's/;cgi.fix_pathinfo=1/cgi.fix_pathinfo=0/' /etc/php.ini\nfi\n\n# ==========================================================\n# NEU: PHP-FPM für Nginx und Port 9000 konfigurieren (Rocky 9 Fix)\n# ==========================================================\nsudo sed -i 's/user = apache/user = nginx/g' /etc/php-fpm.d/www.conf\nsudo sed -i 's/group = apache/group = nginx/g' /etc/php-fpm.d/www.conf\nsudo sed -i 's|listen = /run/php-fpm/www.sock|listen = 127.0.0.1:9000|g' /etc/php-fpm.d/www.conf\n# ==========================================================\n\nsudo systemctl enable php-fpm\nsudo systemctl enable nginx\nsudo systemctl restart php-fpm\nsudo systemctl restart nginx\n\n# Composer installieren\nif [ ! -e /usr/local/bin/composer ]; then\n curl -sS https://getcomposer.org/installer | php\n sudo mv composer.phar /usr/local/bin/composer\n sudo chmod +x /usr/local/bin/composer\nfi\n\n# Laravel Code klonen (über /tmp, da das Zielverzeichnis schon existiert)\nsudo git clone https://github.com/ideadevice/quickstart-basic.git /tmp/laravel-temp\nsudo cp -r /tmp/laravel-temp/* /var/www/laravel/\nsudo cp -r /tmp/laravel-temp/.[a-zA-Z0-9]* /var/www/laravel/ || true\n\n# Falls das Repo keine .env hat, kopieren wir die Example\nif [ ! -f /var/www/laravel/.env ]; then\n  sudo cp /var/www/laravel/.env.example /var/www/laravel/.env\nfi\n\n# Datenbank-Host dynamisch mit der IP-Adresse der Datenbank-VM eintragen\nsudo sed -i 's/DB_HOST=.*/DB_HOST=@@{MySQL.address}@@/' /var/www/laravel/.env\n\n# Composer Install (mit ignore-platform-reqs für ältere Laravel Versionen)\nsudo su - -c \"cd /var/www/laravel; composer install --ignore-platform-reqs\"\n\n# Datenbank-Migration nur auf der ersten VM (calm_array_index == 0) ausführen\nif [ \"@@{calm_array_index}@@\" == \"0\" ]; then\n sudo su - -c \"cd /var/www/laravel; php artisan migrate\"\nfi\n\n# Berechtigungen setzen und Webserver final neustarten\nsudo chown -R nginx:nginx /var/www/laravel\nsudo chmod -R 777 /var/www/laravel/\nsudo systemctl restart nginx",
